# Copy to .env and fill in your values. The .env file is gitignored.

# Google Cloud Speech-to-Text REST API key.
# Create at: https://console.cloud.google.com/apis/credentials
# Restrict to "Cloud Speech-to-Text API" only.
GOOGLE_STT_API_KEY=

# BCP-47 primary language code (e.g. en-US, ru-RU, de-DE).
GOOGLE_STT_PRIMARY_LANGUAGE=en-US

# Up to 3 alternative languages, comma-separated. Google picks the best match per utterance.
GOOGLE_STT_ALT_LANGUAGES=

# Recognition model. Options: latest_long, latest_short, command_and_search, phone_call, video, default.
# latest_long is the right default for meeting-length audio chunks.
GOOGLE_STT_MODEL=latest_long
