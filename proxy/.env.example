# ── Memora proxy config — copy to .env and fill in. The .env file is gitignored. ──

# ===== STT (stt-server.py, port 8766) =====
# Which engine handles transcription, and what to fall back to.
STT_PROVIDER=groq            # groq | whisper | google   (default: groq)
STT_FALLBACK=whisper         # whisper | google | none   (default: whisper)
STT_LANGUAGE=                # empty/auto = auto-detect (handles RU/UK/EN code-switching). Or e.g. ru, uk, en

# Groq (OpenAI-compatible). Get a key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=whisper-large-v3-turbo
# GROQ_URL=https://api.groq.com/openai/v1/audio/transcriptions
GROQ_CONNECT_TIMEOUT=2       # seconds — fast fail-over if Groq is unreachable
GROQ_READ_TIMEOUT=15         # seconds

# Local whisper fallback (faster-whisper). MODEL_SIZE is an alias for WHISPER_MODEL.
WHISPER_MODEL=small          # tiny | base | small | medium | large-v3
# MODEL_SIZE=small           # alias (per-machine override)
WHISPER_DEVICE=cpu           # cpu | cuda
WHISPER_COMPUTE=int8         # int8 | int8_float16 | float16 | float32

# Resilience / queue (tune per machine)
STT_MAX_CONCURRENCY=         # default 4 for groq, 1 for whisper
STT_MAX_QUEUE=6              # drop oldest waiting chunk beyond this
STT_MAX_AUDIO_MB=25          # Groq hard limit; bigger chunks are dropped
STT_MIN_AUDIO_BYTES=1200     # skip near-empty chunks
STT_MIN_RMS=0.004            # skip near-silent chunks (VAD noise); 0 = disable
STT_WARMUP=1                 # warm the whisper model at startup (1/0)

# ===== Google STT (legacy / STT_PROVIDER=google) =====
# Create at https://console.cloud.google.com/apis/credentials, restrict to Cloud Speech-to-Text.
GOOGLE_STT_API_KEY=
GOOGLE_STT_PRIMARY_LANGUAGE=ru-RU
GOOGLE_STT_ALT_LANGUAGES=uk-UA,en-US
GOOGLE_STT_MODEL=latest_long

# ===== Per-machine examples =====
# Weak laptop, fully local:   STT_PROVIDER=whisper   MODEL_SIZE=small   WHISPER_COMPUTE=int8
# Main PC, cloud:             STT_PROVIDER=groq      GROQ_API_KEY=...
# Main PC, local GPU:         STT_PROVIDER=whisper   WHISPER_MODEL=large-v3   WHISPER_DEVICE=cuda   WHISPER_COMPUTE=float16
